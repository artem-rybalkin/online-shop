# ── REQUIRED — copy this file to .env and fill in all values ─────────────────
# Never commit .env to version control.

# Database
MYSQL_ROOT_PASSWORD=change-me-strong-password
DB_PASSWORD=change-me-strong-password

# JWT — minimum 32 random characters
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-minimum-32-random-characters-here

# ── OPTIONAL — defaults shown ─────────────────────────────────────────────────

# CORS — comma-separated allowed origins (no spaces)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8081

# Auth rate limiting (per IP, fixed window)
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW=60

# Set to true once the app is served over HTTPS, so the JWT auth cookie gets the Secure flag.
COOKIE_SECURE=false
