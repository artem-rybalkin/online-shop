{
  "info": {
    "name": "Online Shop API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('runId')) {",
          "    pm.collectionVariables.set('runId', Date.now().toString());",
          "}"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "runId", "value": "" },
    { "key": "username", "value": "" },
    { "key": "email", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "checkoutSessionId", "value": "" },
    { "key": "removalSessionId", "value": "" },
    { "key": "removalCartItemId", "value": "" },
    { "key": "ownershipCartItemId", "value": "" },
    { "key": "orderId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /actuator/health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/actuator/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('status UP', () => pm.expect(pm.response.json().status).to.eql('UP'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Setup",
      "item": [
        {
          "name": "POST /api/products/reset-stock (no admin JWT -> 403)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/products/reset-stock"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 403', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/auth/login (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"admin\",\"password\":\"admin\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/products/reset-stock (negative stock -> 400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/products/reset-stock?stock=-1"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', () => pm.response.to.have.status(400));",
                  "pm.test('stock cannot be negative message', () => pm.expect(pm.response.json().message).to.eql('Stock cannot be negative'));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/products/reset-stock",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/products/reset-stock"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('stock reset to 9999', () => pm.expect(pm.response.json().stock).to.eql(9999));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/auth/register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"postman-user-{{runId}}\",\"password\":\"password123\",\"email\":\"postman-{{runId}}@example.com\"}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('username', 'postman-user-' + pm.collectionVariables.get('runId'));",
                  "pm.collectionVariables.set('email', 'postman-' + pm.collectionVariables.get('runId') + '@example.com');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('returns the registered username', () => pm.expect(pm.response.json().username).to.eql(pm.collectionVariables.get('username')));",
                  "pm.test('sets jwt cookie', () => pm.expect(pm.cookies.has('jwt')).to.be.true);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/auth/login (no email field, like the real frontend)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"{{username}}\",\"password\":\"password123\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('returns the username', () => pm.expect(pm.response.json().username).to.eql(pm.collectionVariables.get('username')));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/auth/me (authenticated)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('returns the logged-in username', () => pm.expect(pm.response.json().username).to.eql(pm.collectionVariables.get('username')));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/auth/logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/logout"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('expires the jwt cookie', () => {",
                  "  // Max-Age=0 makes a real cookie jar delete the cookie outright (not store '').",
                  "  pm.expect(pm.cookies.get('jwt')).to.be.undefined;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/auth/me (after logout -> 401)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/auth/login (wrong password -> 401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"{{username}}\",\"password\":\"wrong-password\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 401', () => pm.response.to.have.status(401));",
                  "pm.test('generic invalid-credentials message', () => pm.expect(pm.response.json().message).to.eql('Invalid username or password'));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/auth/register (duplicate username -> 400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"{{username}}\",\"password\":\"password123\",\"email\":\"another-{{runId}}@example.com\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', () => pm.response.to.have.status(400));",
                  "pm.test('username already exists', () => pm.expect(pm.response.json().error).to.eql('Username already exists'));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/auth/register (blank username -> 400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"\",\"password\":\"password123\",\"email\":\"blank-username-{{runId}}@example.com\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', () => pm.response.to.have.status(400));",
                  "pm.test('username required message', () => pm.expect(pm.response.json().message).to.eql('Username is required'));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/auth/register (blank password -> 400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"postman-blankpw-{{runId}}\",\"password\":\"\",\"email\":\"blank-pw-{{runId}}@example.com\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', () => pm.response.to.have.status(400));",
                  "pm.test('password required message', () => pm.expect(pm.response.json().message).to.eql('Password is required'));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/auth/register (invalid email -> 400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"postman-bademail-{{runId}}\",\"password\":\"password123\",\"email\":\"not-an-email\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', () => pm.response.to.have.status(400));",
                  "pm.test('invalid email message', () => pm.expect(pm.response.json().message).to.eql('Please provide a valid email address'));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/auth/register (malformed JSON -> 400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{not valid json"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', () => pm.response.to.have.status(400));",
                  "pm.test('malformed body message', () => pm.expect(pm.response.json().message).to.eql('Malformed or missing request body'));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/auth/login (wrong method -> 405)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 405', () => pm.response.to.have.status(405));"
                ]
              }
            }
          ]
        }
      ]
    },
