    {
      "name": "Cart",
      "item": [
        {
          "name": "POST /api/cart/{sessionId}/add (removal session)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/cart/postman-removal-{{runId}}/add",
            "body": {
              "mode": "raw",
              "raw": "{\"productId\":{{productId}},\"quantity\":1}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('removalSessionId', 'postman-removal-' + pm.collectionVariables.get('runId'));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('removalCartItemId', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "DELETE /api/cart/item/{id} (missing sessionId -> 400)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/cart/item/{{removalCartItemId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', () => pm.response.to.have.status(400));",
                  "pm.test('sessionId required message', () => pm.expect(pm.response.json().message).to.eql('sessionId is required'));"
                ]
              }
            }
          ]
        },
        {
          "name": "DELETE /api/cart/item/{id}",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/cart/item/{{removalCartItemId}}?sessionId={{removalSessionId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/cart/{sessionId}/add (checkout session)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/cart/postman-checkout-{{runId}}/add",
            "body": {
              "mode": "raw",
              "raw": "{\"productId\":{{productId}},\"quantity\":1}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('checkoutSessionId', 'postman-checkout-' + pm.collectionVariables.get('runId'));"
                ]
              }
            },
